# OIDC / IdentityServer configuration
#
# These are PLACEHOLDERS. The real values depend on the client
# registration in IdentityServer, which is still being built on the
# backend. Copy this file to .env.local and fill in real values once
# that registration exists - do not commit .env.local.

VITE_OIDC_AUTHORITY=https://identity.example.com
VITE_OIDC_CLIENT_ID=admin-panel
VITE_OIDC_REDIRECT_URI=http://localhost:5173/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/login
VITE_OIDC_SCOPE=openid profile tenant_id offline_access

# Base URL for backend microservice REST calls (see docs/API.md).
VITE_API_BASE_URL=http://localhost:5080
