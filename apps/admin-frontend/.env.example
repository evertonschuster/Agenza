# OIDC configuration - matches the "admin-panel" client registered by
# identity-service's DatabaseSeeder. Copy this file to .env.local (never
# commit .env.local); these localhost values already work against
# `dotnet run --project backend/AppHost` or docker-compose.
#
# services-api must stay in scope: it's the audience services-service's
# AddIdentityServiceAuthentication checks, so REST calls (e.g. /api/tags)
# 401 without it.

VITE_OIDC_AUTHORITY=http://localhost:5081
VITE_OIDC_CLIENT_ID=admin-panel
VITE_OIDC_REDIRECT_URI=http://localhost:5173/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/login
VITE_OIDC_SCOPE=openid profile tenant_id services-api offline_access

# Base URL for backend microservice REST calls (see docs/API.md).
VITE_API_BASE_URL=http://localhost:5080
