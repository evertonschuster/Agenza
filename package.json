{
  "name": "admin-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=apps/admin-frontend",
    "build:frontend": "npm run build --workspace=apps/admin-frontend",
    "test:frontend": "npm run test --workspace=apps/admin-frontend",
    "lint:frontend": "npm run lint --workspace=apps/admin-frontend"
  }
}
